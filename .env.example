# ─────────────────────────────────────────────
# samae-app 환경변수 — 이 파일을 .env.local 로 복사해서 채우세요.
# .env.local 은 절대 커밋하지 마세요 (.gitignore 에 포함됨).
# ─────────────────────────────────────────────

# Supabase (대시보드 → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ 서버 전용 — NEXT_PUBLIC_ 접두사 절대 금지. 클라이언트 번들에 들어가면 안 됨.
SUPABASE_SERVICE_ROLE_KEY=

# 카카오 로그인은 Supabase 대시보드 Authentication → Providers → Kakao 에 등록.
# (앱 코드에는 별도 카카오 키 불필요 — Supabase 가 OAuth 중계)

# 사이트 기본 URL (OAuth redirect 용). 로컬은 http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 로컬 마이그레이션 실행용 DB 연결 문자열 (node scripts/migrate.cjs)
# Supabase → Settings → Database → Connection string → "Session pooler" 의 URI 복사,
# [YOUR-PASSWORD] 부분을 DB 비밀번호로 치환. (앱 런타임엔 불필요, 로컬 도구 전용)
# SUPABASE_DB_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# 결제 (5단계에서 PG 확정 후 채움)
# PORTONE_API_SECRET=
# PAYMENT_WEBHOOK_SECRET=
