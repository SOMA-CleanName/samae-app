# ─────────────────────────────────────────────
# samae-app 환경변수 — 이 파일을 .env.local 로 복사해서 채우세요.
# .env.local 은 절대 커밋하지 마세요 (.gitignore 에 포함됨).
# ─────────────────────────────────────────────

# Supabase (대시보드 → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️ 서버 전용 — NEXT_PUBLIC_ 접두사 절대 금지. 클라이언트 번들에 들어가면 안 됨.
SUPABASE_SERVICE_ROLE_KEY=

# 어드민 데이터 초기화(분석·문의·거래 삭제) 확인용 비밀번호. 서버 전용.
# 미설정 시 초기화 기능이 비활성화됨. 운영진만 공유.
ADMIN_RESET_PASSWORD=

# 카카오 로그인은 Supabase 대시보드 Authentication → Providers → Kakao 에 등록.
# (앱 코드에는 별도 카카오 키 불필요 — Supabase 가 OAuth 중계)

# 사이트 기본 URL (OAuth redirect 용). 로컬은 http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 로컬 마이그레이션 실행용 DB 연결 문자열 (node scripts/migrate.cjs)
# Supabase → Settings → Database → Connection string → "Session pooler" 의 URI 복사,
# [YOUR-PASSWORD] 부분을 DB 비밀번호로 치환. (앱 런타임엔 불필요, 로컬 도구 전용)
# SUPABASE_DB_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# 결제 (5단계에서 PG 확정 후 채움)
# PORTONE_API_SECRET=
# PAYMENT_WEBHOOK_SECRET=

# 행동 분석 → Google Sheets (Apps Script 웹앱 URL, 선택). docs/16 참고
SHEETS_WEBHOOK_URL=

# 운영진 알림 → 디스코드 (새 문의·작가신청 접수 시 운영진 채널 웹훅, 선택). 미설정이면 알림 생략
DISCORD_OPS_WEBHOOK_URL=

# 작가 신청 페이지의 카카오 채널 구독 링크 (예: http://pf.kakao.com/_xxxxx). 미설정이면 '준비중' 표시
NEXT_PUBLIC_KAKAO_CHANNEL_URL=

# Meta(페이스북) 픽셀 ID (광고 전환 추적, 선택). 미설정이면 픽셀 미로딩
NEXT_PUBLIC_FB_PIXEL_ID=
# Meta 전환 API 액세스 토큰 (서버측 Lead 전송, 선택). 미설정이면 CAPI 미전송 —
# 브라우저 픽셀이 놓친 전환(iOS·광고차단)을 서버가 보완하지 못한다.
# 발급: 이벤트 관리자 > 데이터 세트 > 설정 > 전환 API > 액세스 토큰 생성
FB_CAPI_TOKEN=

# 구글 서치 콘솔 사이트 인증 토큰 (선택). 설정하면 layout.tsx 가 <head>에 렌더
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Mixpanel 프로젝트 토큰 (프로덕트 애널리틱스 — 퍼널/리텐션/코호트). 없으면 Mixpanel 비활성(no-op).
NEXT_PUBLIC_MIXPANEL_TOKEN=
# Sentry 에러 추적 — DSN 없으면 Sentry 비활성(no-op).
NEXT_PUBLIC_SENTRY_DSN=
# 소스맵 업로드(빌드타임·선택 — 읽기 쉬운 스택트레이스). 서버 전용, NEXT_PUBLIC_ 금지.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
